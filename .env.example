# Токен бота от @BotFather (обязательно)
BOT_TOKEN=

# --- LLM-провайдер (переключается без правки кода) ---
# LLM_PROVIDER: openrouter (любой OpenAI-совместимый эндпоинт) или anthropic
LLM_PROVIDER=openrouter
# Модель у выбранного провайдера. Для OpenRouter — бесплатный вариант:
LLM_MODEL=moonshotai/kimi-k2.6:free
# base_url OpenAI-совместимого провайдера (для anthropic не используется)
LLM_BASE_URL=https://openrouter.ai/api/v1
# Ключ выбранного провайдера (для openrouter — ключ с openrouter.ai)
LLM_API_KEY=
# Таймаут запроса к LLM, секунды (бесплатные модели отвечают медленнее)
# LLM_TIMEOUT_SECONDS=60

# --- Вернуться на Anthropic: поставить LLM_PROVIDER=anthropic ---
# Тогда используется ANTHROPIC_API_KEY (или LLM_API_KEY) и модель ниже.
ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-sonnet-4-5

# Необязательные настройки (значения по умолчанию):
# DB_URL=sqlite+aiosqlite:///./sales_agent.db
# REMINDERS_POLL_INTERVAL=60

# --- Chat Lead Monitor: Telethon userbot для открытых чатов ---
# Telegram API ID/HASH берутся на https://my.telegram.org/apps
# Лиды сохраняются в CRM пользователя с этим Telegram id:
# CHAT_MONITOR_OWNER_TG_ID=123456789
# CHAT_MONITOR_API_ID=123456
# CHAT_MONITOR_API_HASH=your_api_hash
# CHAT_MONITOR_PHONE=+77001234567
# CHAT_MONITOR_SESSION_PATH=chat_monitor.session
# Если код не приходит в приложение Telegram, можно попробовать SMS:
# CHAT_MONITOR_FORCE_SMS=false
# Начальный список чатов через запятую: usernames или числовые chat_id.
# После старта их можно менять кнопками в боте: Chat Monitor -> Добавить чат.
# CHAT_MONITOR_CHATS=@open_nails_chat,-1001234567890
# Начальный порог сохранения LLM-score 0.0-1.0; дальше меняется кнопками в боте.
# CHAT_MONITOR_MIN_SCORE=0.7

# --- P-1: Allowlist пользователей бота ---
# Comma-separated Telegram user IDs. Пусто = доступ не ограничен.
# Чтобы узнать свой ID: напишите @userinfobot в Telegram.
# ALLOWED_USER_IDS=123456789,987654321

# --- P-2: Дневной лимит LLM-вызовов (0 = без лимита) ---
# Считает все вызовы (анализ, генерация сообщений, скоринг чатов).
# При превышении бот показывает сообщение, chat_monitor пропускает скоринг.
# LLM_DAILY_LIMIT=0

# --- P-4: Heartbeat-мониторинг Chat Monitor ---
# Runner пишет timestamp в файл каждые N минут.
# Скрипт scripts/check_heartbeat.py проверяет свежесть.
# HEARTBEAT_FILE=chat_monitor.heartbeat
# HEARTBEAT_INTERVAL_MINUTES=5

# --- P-7: Автобэкап БД ---
# Скрипт scripts/backup_db.py копирует БД с ротацией.
# BACKUP_DIR=backups
# BACKUP_KEEP=14

# =============================================================================
# --- Клиентская конфигурация (Production Template) ---
# Все параметры ниже позволяют адаптировать бота под нового клиента
# без изменения Python-кода.
# =============================================================================

# --- Домен 2ГИС для ссылок ручной проверки ---
# Казахстан: 2gis.kz (по умолчанию), Россия: 2gis.ru
# GIS_DOMAIN=2gis.kz

# --- Ниша и описание для Chat Monitor и AI-анализа ---
# Описание ниши (используется в LLM-промпте скоринга)
# CHAT_MONITOR_NICHE_DESCRIPTION=маникюр/ногтевой сервис
# Описание целевого лида (кого ищем в чатах)
# CHAT_MONITOR_LEAD_DESCRIPTION=соло-мастер маникюра, который публично упоминает запись клиентов, свободные окна, приём на дому или выезд
# Описание нашего продукта/оффера
# CHAT_MONITOR_OFFER_PRODUCT=сервис записи клиентов через Telegram-бота
# Ключевые слова для первичного фильтра (через запятую). Пусто = встроенные nail-keywords.
# CHAT_MONITOR_KEYWORDS=маникюр,ногти,запись,свободное окошко,принимаю

# --- Настройки AI-анализа компаний ---
# Тип услуг для анализа
# AI_SERVICE_TYPE=digital-услуги (сайт, онлайн-запись, SMM, реклама)
# Наш основной оффер (упоминается если нет онлайн-записи)
# AI_MAIN_OFFER=запись через Telegram-бота
# Язык генерируемых сообщений
# AI_RESPONSE_LANGUAGE=русском
