# Токен бота от @BotFather (обязательно)
BOT_TOKEN=

# --- Окружение: development / production ---
# В production пустой ALLOWED_USER_IDS — ОШИБКА запуска (fail-closed):
# бот без allowlist доступен любому пользователю Telegram.
# ENVIRONMENT=development
# Production: ENVIRONMENT=production
# После реальной ротации утёкших ключей/сессий:
# SECRETS_ROTATED_AT=2026-07-20T16:00:00Z

# --- LLM-провайдер (переключается без правки кода) ---
# LLM_PROVIDER: openrouter (любой OpenAI-совместимый эндпоинт) или anthropic
LLM_PROVIDER=openrouter
# Модель у выбранного провайдера. Для OpenRouter — бесплатный вариант:
LLM_MODEL=moonshotai/kimi-k2.6:free
# base_url OpenAI-совместимого провайдера (для anthropic не используется)
LLM_BASE_URL=https://openrouter.ai/api/v1
# LLM_ALLOWED_HOSTS=openrouter.ai,api.openai.com
# Ключ выбранного провайдера (для openrouter — ключ с openrouter.ai)
LLM_API_KEY=
# Таймаут запроса к LLM, секунды (бесплатные модели отвечают медленнее)
# LLM_TIMEOUT_SECONDS=60
# LLM_RETRY_ATTEMPTS=2
# LLM_RETRY_BASE_DELAY_SECONDS=1.0

# --- Вернуться на Anthropic: поставить LLM_PROVIDER=anthropic ---
# Тогда используется ANTHROPIC_API_KEY (или LLM_API_KEY) и модель ниже.
ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-sonnet-4-5

# Необязательные настройки (значения по умолчанию):
# DB_URL=sqlite+aiosqlite:///./sales_agent.db
# REMINDERS_POLL_INTERVAL=60

# --- PostgreSQL (обязательно для ENVIRONMENT=production) ---
# SQLite — один писатель; при параллельной работе бота, chat_monitor и
# поллера напоминаний возможны блокировки. PostgreSQL — промышленная БД.
# Запуск PG/Redis в Docker: docker compose --profile postgres up -d postgres redis
# DB_URL=postgresql+asyncpg://sales_agent:SECRET@postgres:5432/sales_agent
# POSTGRES_PASSWORD=SECRET  (используется docker-compose postgres-сервисом)
# REDIS_PASSWORD=SECRET     (используется docker-compose redis-сервисом)
# REDIS_URL=redis://:SECRET@redis:6379/0
# AUTO_CREATE_SCHEMA=false
# Перед production-стартом: docker compose --profile postgres run --rm migrate

# --- SECURITY-6: Redis для FSM storage и идемпотентности ---
# Если задан — FSM состояния сохраняются между рестартами, идемпотентность
# работает в multi-instance окружении. Без Redis — memory storage (потеря при рестарте).
# Production требует Redis с паролем, без exposed public port:
# REDIS_URL=redis://:STRONG_PASSWORD@redis:6379/0

# --- Chat Lead Monitor: Telethon userbot для открытых чатов ---
# ВАЖНО: используйте ОТДЕЛЬНЫЙ сервисный аккаунт Telegram, НЕ личный!
# Файл chat_monitor.session = полный доступ к аккаунту. Бот выставляет ему
# права 0600 при старте (Linux). Не включайте его в бэкапы.
# Telegram API ID/HASH берутся на https://my.telegram.org/apps
# Лиды сохраняются в CRM пользователя с этим Telegram id:
# CHAT_MONITOR_OWNER_TG_ID=123456789
# CHAT_MONITOR_API_ID=123456
# CHAT_MONITOR_API_HASH=your_api_hash
# CHAT_MONITOR_PHONE=+77001234567
# CHAT_MONITOR_SESSION_PATH=chat_monitor.session
# Если код не приходит в приложение Telegram, можно попробовать SMS:
# CHAT_MONITOR_FORCE_SMS=false
# Начальный список чатов через запятую: usernames или числовые chat_id.
# После старта их можно менять кнопками в боте: Chat Monitor -> Добавить чат.
# CHAT_MONITOR_CHATS=@open_nails_chat,-1001234567890
# Начальный порог сохранения LLM-score 0.0-1.0; дальше меняется кнопками в боте.
# CHAT_MONITOR_MIN_SCORE=0.7
# --- CHATMON-1: Cooldown на автора, секунды (0 = отключён) ---
# После скоринга сообщения автора его следующие сообщения пропускаются
# в течение cooldown — флуд одного автора не съедает LLM-бюджет.
# CHAT_MONITOR_AUTHOR_COOLDOWN_SECONDS=3600
# CHAT_MONITOR_QUEUE_SIZE=200
# CHAT_MONITOR_WORKER_COUNT=2
# CHAT_MONITOR_MAX_CHATS=100

# --- P-1: Allowlist пользователей бота ---
# Comma-separated Telegram user IDs. Пусто = доступ не ограничен.
# Чтобы узнать свой ID: напишите @userinfobot в Telegram.
# ALLOWED_USER_IDS=123456789,987654321

# --- P-2: Дневной лимит LLM-вызовов ---
# Считает все вызовы (анализ, генерация сообщений, скоринг чатов).
# При превышении бот показывает сообщение, chat_monitor пропускает скоринг.
# Production: обязательный ненулевой лимит на каждого owner:
# LLM_DAILY_LIMIT=100

# --- SEC-FIX: общий rate limit всех апдейтов на пользователя ---
# Закрывает обход через чередование message/callback.
# USER_GLOBAL_RATE_LIMIT_SECONDS=0.5

# --- SEC-FIX: лимит активных напоминаний на пользователя ---
# Защита от раздувания БД и DoS фонового поллера напоминаний.
# MAX_ACTIVE_REMINDERS_PER_USER=100

# --- PERF-3: Максимум одновременных LLM-вызовов ---
# Бот + chat_monitor могут одновременно инициировать вызовы; семафор
# ограничивает параллелизм (backpressure вместо бурста по free-tier API).
# LLM_MAX_CONCURRENCY=3

# --- PERF-2: Кэш AI-анализа ---
# Повторный анализ той же компании (name+address+phone+website) берётся из
# кэша 24 часа и НЕ тратит дневной лимит. Redis если задан, иначе in-memory.

# --- P-4: Heartbeat-мониторинг Chat Monitor ---
# Runner пишет timestamp в файл каждые N минут.
# Скрипт scripts/check_heartbeat.py проверяет свежесть.
# HEARTBEAT_FILE=chat_monitor.heartbeat
# HEARTBEAT_INTERVAL_MINUTES=5

# --- External API retry policy ---
# Bounded retries for transient 429/5xx/network failures only.
# EXTERNAL_RETRY_ATTEMPTS=2
# EXTERNAL_RETRY_BASE_DELAY_SECONDS=0.5

# --- SEC-FIX-4: Retention (152-ФЗ: не храним ПДн дольше необходимого) ---
# Фоновая очистка раз в сутки: тексты чатов/журналы старше N дней удаляются.
# RETENTION_LLM_CALL_LOG_DAYS=30
# RETENTION_AUDIT_LOG_DAYS=90
# RETENTION_CHAT_MESSAGE_TEXT_DAYS=30
# RETENTION_DELETED_LEAD_DAYS=30
# RETENTION_CLEANUP_INTERVAL_SECONDS=86400

# --- SEC-FIX-5: Шифрование ПДн в БД (тексты чатов) ---
# Ключ Fernet. Пусто = шифрование выключено (обратная совместимость).
# Сгенерировать: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# ВНИМАНИЕ: без ключа зашифрованные данные не расшифровать. Храни отдельно от БД.
# PII_ENCRYPTION_KEY=
# BACKUP_ENCRYPTION_KEY=  # отдельный ключ, не равный PII_ENCRYPTION_KEY

# --- P-7: Автобэкап БД ---
# Скрипт scripts/backup_db.py: SQLite — через backup API (WAL-safe),
# PostgreSQL — через pg_dump (должен быть установлен клиент PG).
# BACKUP_DIR=backups
# BACKUP_KEEP=14

# --- MONITORING-2: Sentry (опционально) ---
# DSN из настроек проекта на sentry.io. Пусто = отключён (ошибки только в логах).
# Отправляются: необработанные исключения хендлеров, сбои фоновых циклов,
# ERROR+ логи; с контекстом tg user_id и FSM-состояния.
# SENTRY_DSN=https://...@o....ingest.sentry.io/...
# SENTRY_ENVIRONMENT=production
# SENTRY_USER_HASH_SALT=separate-random-secret
# Доля транзакций performance-мониторинга (0.0 = только ошибки):
# SENTRY_TRACES_SAMPLE_RATE=0.0

# =============================================================================
# --- Клиентская конфигурация (Production Template) ---
# Все параметры ниже позволяют адаптировать бота под нового клиента
# без изменения Python-кода.
# =============================================================================

# --- Домен 2ГИС для ссылок ручной проверки ---
# Казахстан: 2gis.kz (по умолчанию), Россия: 2gis.ru
# GIS_DOMAIN=2gis.kz

# --- Ниша и описание для Chat Monitor и AI-анализа ---
# Описание ниши (используется в LLM-промпте скоринга)
# CHAT_MONITOR_NICHE_DESCRIPTION=маникюр/ногтевой сервис
# Описание целевого лида (кого ищем в чатах)
# CHAT_MONITOR_LEAD_DESCRIPTION=соло-мастер маникюра, который публично упоминает запись клиентов, свободные окна, приём на дому или выезд
# Описание нашего продукта/оффера
# CHAT_MONITOR_OFFER_PRODUCT=сервис записи клиентов через Telegram-бота
# Ключевые слова для первичного фильтра (через запятую). Пусто = встроенные nail-keywords.
# CHAT_MONITOR_KEYWORDS=маникюр,ногти,запись,свободное окошко,принимаю

# --- Настройки AI-анализа компаний ---
# Тип услуг для анализа
# AI_SERVICE_TYPE=digital-услуги (сайт, онлайн-запись, SMM, реклама)
# Наш основной оффер (упоминается если нет онлайн-записи)
# AI_MAIN_OFFER=запись через Telegram-бота
# Язык генерируемых сообщений
# AI_RESPONSE_LANGUAGE=русском
